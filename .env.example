# Saxo Bank API Configuration
# Copy this file to .env and fill in your values

# Access token from Saxo Developer Portal
SAXO_ACCESS_TOKEN=your_access_token_here

# Base URL (sim = simulation environment)
SAXO_BASE_URL=https://gateway.saxobank.com/sim/openapi

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Discord Webhooks
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
DISCORD_ENTRY_WEBHOOK_URL=your_discord_entry_webhook_url_here

# Timeframe Configuration (optional - overrides currency JSON config)
# These are set by GitHub Actions workflows, but can be overridden locally
# PRIMARY_TIMEFRAME=1h        # 主時間足 (1h, 15m, etc.)
# PRIMARY_RANGE=10d           # 主時間足のデータ取得範囲
# SECONDARY_TIMEFRAME=4h      # MTFフィルター用時間足
# SECONDARY_RANGE=30d         # MTF時間足のデータ取得範囲
